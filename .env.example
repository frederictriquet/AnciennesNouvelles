# NE PAS VERSIONNER CE FICHIER — copier en .env et remplir les valeurs

TELEGRAM_BOT_TOKEN=123456789:AABBccDDeeFFggHH...

META_APP_ID=1234567890123456
META_APP_SECRET=abcdef1234567890abcdef1234567890

# Les tokens Meta NE sont PAS stockés ici — source de vérité : table meta_tokens en DB
# Gestion via : python -m ancnouv auth meta

# Token du serveur d'images (requis si image_hosting.backend = remote)
# Générer : python -c "import secrets; print(secrets.token_hex(32))"
IMAGE_SERVER_TOKEN=

# ID Telegram pour les notifications crash systemd (facultatif)
TELEGRAM_CHAT_ID=

# Surcharge du chemin DB (optionnel — utile en CI/CD)
ANCNOUV_DB_PATH=
